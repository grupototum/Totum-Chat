# Imagem do container. Fixe uma release validada do Chat Totum ou um digest imutável.
# Não use latest em produção.
LOBE_CHAT_IMAGE_TAG=<replace_me>

# Provedores gratuitos/sem custo extra encontrados em /home/totum/totum-chat/.env
GROQ_API_KEY=<replace_me>
GOOGLE_API_KEY=<replace_me>
OLLAMA_PROXY_URL=<replace_me>

# Controle de acesso
ACCESS_CODE=<replace_me>

# Bootstrap dos agentes
DEFAULT_AGENT_CONFIG=<replace_me>
SYSTEM_AGENT=<replace_me>
AGENTS_INDEX_URL=<replace_me>

# Integração Alexandria
ALEXANDRIA_API_URL=<replace_me>
ALEXANDRIA_ENABLED=<replace_me>
RAG_CHUNK_SIZE=<replace_me>
RAG_SEARCH_LIMIT=<replace_me>
